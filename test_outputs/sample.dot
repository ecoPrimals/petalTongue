digraph PetalTongue {
  // Graph attributes
  rankdir=LR;
  bgcolor="#141822";
  node [style=filled, fontcolor=white, fontname="sans-serif"];
  edge [color="#6b7280"];

  // Primals
  "petaltongue-headless" [label="petalTongue Headless\n100%", fillcolor="#4ade80"];
  "biomeos-1" [label="biomeOS\n100%", fillcolor="#4ade80"];
  "songbird-1" [label="Songbird\n75%", fillcolor="#facc15"];

  // Connections
  "biomeos-1" -> "petaltongue-headless" [label="monitors"];
  "songbird-1" -> "petaltongue-headless" [label="sends_data"];
}
