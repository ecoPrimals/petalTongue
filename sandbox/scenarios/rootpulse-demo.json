{
  "name": "RootPulse - Temporal Coordination Visualization",
  "description": "DAG timeline, linear history, and semantic attribution",
  "version": "1.0.0",
  "mode": "rootpulse",
  
  "ui_config": {
    "theme": "benchtop-dark",
    "layout": "temporal-split",
    "panels": {
      "dag_timeline": {
        "position": "top",
        "height_percent": 60,
        "title": "rhizoCrypt DAG - Present/Future"
      },
      "linear_history": {
        "position": "bottom",
        "height_percent": 40,
        "title": "LoamSpine Linear - The Past"
      }
    }
  },
  
  "temporal_architecture": {
    "dag": {
      "name": "rhizoCrypt",
      "type": "present_future",
      "characteristics": [
        "branching_possibilities",
        "lock_free",
        "10x_to_100x_faster",
        "flexible_merging"
      ]
    },
    "linear": {
      "name": "LoamSpine",
      "type": "past",
      "characteristics": [
        "immutable",
        "provable",
        "ordered",
        "anchored"
      ]
    },
    "dehydration": {
      "enabled": true,
      "timescales": ["nanosecond", "second", "hour", "day", "month", "year"],
      "animation_enabled": true
    }
  },
  
