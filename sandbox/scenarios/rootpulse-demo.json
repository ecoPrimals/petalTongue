  "branches": [
    {
      "name": "main",
      "color": "#a6e3a1",
      "head": "commit-6",
      "commits": ["commit-1", "commit-2", "commit-4", "commit-5", "commit-6"]
    },
    {
      "name": "feature/discovery",
      "color": "#89b4fa",
      "head": "commit-3",
      "commits": ["commit-3"],
      "merged_into": "main",
      "merged_at": "commit-5"
    }
  },
  
  "anchors": [
    {
      "type": "cryptographic",
      "commits": ["commit-1", "commit-2", "commit-4", "commit-5", "commit-6"],
      "description": "BearDog cryptographic signatures"
    },
    {
      "type": "atomic",
      "commits": ["commit-1", "commit-2", "commit-4", "commit-5", "commit-6"],
      "description": "Atomic clock timestamps"
    },
    {
      "type": "causal",
      "commits": ["commit-1", "commit-2", "commit-4", "commit-5", "commit-6"],
      "description": "Causal dependency ordering"
    },
    {
      "type": "consensus",
      "commits": ["commit-1", "commit-2", "commit-5", "commit-6"],
      "description": "Multi-party consensus"
    }
  ],
  
  "dehydration_demo": {
    "enabled": true,
    "levels": [
      {
        "name": "Full Resolution",
        "timescale": "second",
        "visible_commits": ["commit-1", "commit-2", "commit-3", "commit-4", "commit-5", "commit-6"]
      },
      {
        "name": "Hour Collapsed",
        "timescale": "hour",
        "visible_commits": ["commit-1", "commit-5", "commit-6"]
      },
      {
        "name": "Day Collapsed",
        "timescale": "day",
        "visible_commits": ["commit-1", "commit-6"]
      }
    ]
  },
  
  "visualizations": {
    "dag_rendering": {
      "node_size": 40,
      "edge_curve": "bezier",
      "branch_spacing": 50,
      "animate_commits": true,
      "show_messages": true,
      "show_hashes": true
    },
    "linear_rendering": {
      "node_size": 30,
      "timeline_horizontal": true,
      "anchor_indicators": true,
      "dehydration_zones": true
    },
    "attribution_panel": {
      "show_contributors": true,
      "show_concepts": true,
      "show_weights": true,
      "braiding_visualization": true
    }
  },
  
  "interactions": {
    "click_commit": {
      "action": "show_details",
      "panel": "right_sidebar"
    },
    "hover_commit": {
      "action": "show_tooltip",
      "content": ["message", "author", "timestamp", "attribution"]
    },
    "drag_timeline": {
      "action": "pan",
      "smooth": true
    },
    "scroll_timeline": {
      "action": "zoom",
      "center_on_mouse": true
    }
  },
  
  "animations": {
    "new_commit": {
      "duration_ms": 500,
      "easing": "spring",
      "effects": ["fade-in", "scale-up", "pulse"]
    },
    "branch_merge": {
      "duration_ms": 800,
      "easing": "ease-in-out",
      "effects": ["arc-path", "particle-flow", "celebrate"]
    },
    "dehydration": {
      "duration_ms": 1000,
      "easing": "ease-out",
      "effects": ["fade-out", "collapse", "compress"]
    },
    "attribution_braid": {
      "duration_ms": 600,
      "easing": "ease-in-out",
      "effects": ["weave", "color-blend", "flow"]
    }
  },
  
  "demo_sequence": [
    {
      "timestamp": 0,
      "action": "show_dag_timeline",
      "description": "Display full DAG with branches"
    },
    {
      "timestamp": 2000,
      "action": "highlight_main_branch",
      "description": "Pulse main branch - linear progression"
    },
    {
      "timestamp": 4000,
      "action": "highlight_feature_branch",
      "description": "Show feature branch - parallel work"
    },
    {
      "timestamp": 6000,
      "action": "animate_merge",
      "description": "Merge animation - branches converge"
    },
    {
      "timestamp": 8000,
      "action": "show_linear_history",
      "description": "Display LoamSpine linear history"
    },
    {
      "timestamp": 10000,
      "action": "show_anchors",
      "description": "Display multiple anchor types"
    },
    {
      "timestamp": 12000,
      "action": "click_commit",
      "target": "commit-5",
      "description": "Inspect merge commit - SweetGrass attribution"
    },
    {
      "timestamp": 14000,
      "action": "demonstrate_dehydration",
      "description": "Temporal collapse - hour → day → month"
    },
    {
      "timestamp": 16000,
      "action": "show_attribution_braiding",
      "description": "Semantic contribution visualization"
    },
    {
      "timestamp": 18000,
      "action": "loop",
      "description": "Return to full DAG view"
    }
  ]
}

